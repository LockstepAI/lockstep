{
  "name": "@lockstepai/lockstep",
  "version": "0.1.7",
  "type": "module",
  "description": "Guided terminal CLI for Lockstep Dev.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lockstep": "./dist/bin/lockstep.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx watch src/bin/lockstep.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:minify": "find dist -name '*.js' -not -name '*.d.ts' -exec npx terser {} --compress --mangle --output {} \\;",
    "prepublishOnly": "npm run build && npm run build:minify && find dist -name '*.js.map' -delete && find dist -name '*.d.ts.map' -delete"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LockstepAI/lockstep.git"
  },
  "homepage": "https://github.com/LockstepAI/lockstep#readme",
  "bugs": {
    "url": "https://github.com/LockstepAI/lockstep/issues"
  },
  "author": "LockstepAI",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "json-stable-stringify": "^1.3.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/json-stable-stringify": "^1.1.0",
    "@types/node": "^22.0.0",
    "terser": "^5.46.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "lockstep",
    "lockstepai",
    "ai",
    "verification",
    "codex",
    "claude",
    "openai",
    "coding-agent",
    "cryptographic",
    "hash",
    "proof",
    "receipt",
    "ai-agent",
    "devtools",
    "ci-cd",
    "trust",
    "compliance"
  ]
}
