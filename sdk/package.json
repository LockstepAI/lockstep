{
  "name": "@lockstepai/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript client for Lockstep Dev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LockstepAI/lockstep.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/LockstepAI/lockstep/tree/main/sdk#readme",
  "bugs": {
    "url": "https://github.com/LockstepAI/lockstep/issues"
  },
  "keywords": [
    "lockstep",
    "lockstep-dev",
    "sdk",
    "typescript",
    "api-client",
    "receipts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.1"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
